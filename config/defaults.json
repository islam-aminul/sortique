{
  "jpeg_quality": 85,
  "max_resolution": [3840, 2160],
  "threads": 4,
  "verify_copies": false,
  "follow_symlinks": false,
  "musicbrainz_enabled": false,

  "screenshot_resolutions": [
    [750, 1334],
    [1080, 1920],
    [1125, 2436],
    [1170, 2532],
    [1179, 2556],
    [1242, 2688],
    [1284, 2778],
    [1290, 2796],
    [1440, 2560],
    [1440, 3200],
    [1536, 2048],
    [2048, 2732],
    [1080, 2400],
    [1440, 3120],
    [2160, 3840],
    [828, 1792]
  ],
  "screenshot_tolerance": 10,

  "editor_patterns": [
    "Adobe Photoshop",
    "Adobe Lightroom",
    "GIMP",
    "Snapseed",
    "Google Photos",
    "Picasa",
    "Instagram",
    "VSCO",
    "Afterlight",
    "PicsArt"
  ],
  "editor_exclusions": ["Picasa"],

  "social_media_image_patterns": [
    "IMG-*-WA*",
    "FB_IMG_*",
    "received_*",
    "????????-????-????-????-????????????.*"
  ],
  "social_media_video_patterns": [
    "VID-*-WA*",
    "FB_VID_*"
  ],
  "motion_photo_patterns": [
    "*_MVIMG_*",
    "MOTION_*"
  ],
  "screenshot_filename_patterns": [
    "Screenshot_*",
    "SCR_*"
  ],
  "voice_note_patterns": [
    "Recording_*",
    "Voice_*",
    "Audio_*"
  ],
  "burst_filename_patterns": [
    "*_BURST*",
    "*_BRACKETED*"
  ],

  "skip_filename_patterns": [
    "*.supplemental-metadata.json"
  ],

  "call_recording_patterns": [
    "SIM*_*_*",
    "Call_[0-9]*",
    "callrecord_*"
  ],

  "sidecar_extensions": [
    ".thm",
    ".srt",
    ".sub",
    ".lrc",
    ".xmp",
    ".aae"
  ],

  "date_regex_patterns": [
    "(?P<Y>\\d{4})[\\-_.](?P<m>\\d{2})[\\-_.](?P<d>\\d{2})[\\-_. T](?P<H>\\d{2})[\\-_.](?P<M>\\d{2})[\\-_.](?P<S>\\d{2})",
    "(?P<Y>\\d{4})(?P<m>\\d{2})(?P<d>\\d{2})[\\-_. T]?(?P<H>\\d{2})(?P<M>\\d{2})(?P<S>\\d{2})",
    "(?P<Y>\\d{4})[\\-_.](?P<m>\\d{2})[\\-_.](?P<d>\\d{2})",
    "(?P<d>\\d{2})[\\-_.](?P<m>\\d{2})[\\-_.](?P<Y>\\d{4})"
  ]
}
